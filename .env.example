# AuraCue local AI provider configuration.
# Copy to .env.local or load into your shell; do not commit real API keys.

AURACUE_AI_PROVIDER=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=replace-with-your-deepseek-key

# Alternative OpenAI-compatible names are also supported by apps/web/server/ai/openai-compatible-provider.ts.
# AI_PROVIDER=deepseek
# AI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat
# AI_API_KEY=replace-with-your-provider-key
