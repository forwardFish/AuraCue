.page {
  min-height: 100vh;
  padding: 80rpx 40rpx 40rpx;
  background: #fff8f5;
  color: #151642;
  text-align: center;
}
.brand {
  font-size: 36rpx;
  letter-spacing: 8rpx;
}
.title {
  margin: 64rpx 0 40rpx;
  font-size: 56rpx;
  font-family: serif;
}
.story-card {
  min-height: 520rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #f7d4eb, #efe4ff);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-family: serif;
}
.channels {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 32rpx;
}
.channels button, .cancel {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.84);
  color: #151642;
}
.cancel {
  margin-top: 28rpx;
}
