page {
  background: #f8d0e3;
}

.share-story-page {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 48px 24px 30px;
  overflow: hidden;
  background: linear-gradient(180deg, #fdf0f3 0%, #f8d0e3 48%, #f5b0c9 100%);
  color: #2a1a4a;
  font-family: Inter, system-ui, sans-serif;
}

.decor-star {
  position: absolute;
  color: #d4af37;
  font-size: 10px;
}

.star-a {
  top: 116px;
  left: 46px;
}

.star-b {
  top: 92px;
  right: 58px;
}

.share-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.close-button,
.header-space {
  width: 42px;
  height: 42px;
}

.close-button {
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.58);
  background: rgba(255, 255, 255, 0.72);
  color: #2a1a4a;
  font-size: 11px;
}

.close-button::after,
.round-action::after {
  border: 0;
}

.brand {
  color: #c8a04f;
  font-family: Georgia, serif;
  font-size: 22px;
  font-weight: 600;
}

.title-block {
  text-align: center;
  margin-bottom: 18px;
}

.eyebrow,
.page-title {
  display: block;
}

.eyebrow {
  color: rgba(42, 26, 74, 0.75);
  font-size: 14px;
}

.page-title {
  margin-top: 4px;
  font-family: Georgia, serif;
  font-size: 31px;
  line-height: 36px;
  font-weight: 700;
}

.title-rule {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-top: 9px;
  color: #d4af37;
  font-size: 9px;
}

.title-rule view {
  width: 52px;
  height: 1px;
  background: rgba(212, 175, 55, 0.46);
}

.story-card {
  position: relative;
  width: 100%;
  aspect-ratio: 9 / 16;
  max-height: 548px;
  border-radius: 24px;
  overflow: hidden;
  color: #ffffff;
  background: linear-gradient(165deg, #2a1a4a 0%, #8d5bff 42%, #f48fb1 72%, #d4af37 100%);
  border: 1px solid rgba(212, 175, 55, 0.55);
  box-shadow: 0 14px 32px rgba(42, 26, 74, 0.22);
}

.renderer-output {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.inner-border {
  position: absolute;
  inset: 10px;
  border: 1px solid rgba(212, 175, 55, 0.38);
  border-radius: 18px;
}

.card-top {
  position: relative;
  z-index: 1;
  display: grid;
  gap: 5px;
  padding-top: 34px;
  text-align: center;
}

.card-brand {
  color: #d4af37;
  font-size: 13px;
  letter-spacing: 3px;
}

.card-title {
  font-family: Georgia, serif;
  font-size: 29px;
}

.card-date {
  color: rgba(255, 255, 255, 0.82);
  font-size: 12px;
}

.card-panel {
  position: absolute;
  z-index: 1;
  left: 14px;
  right: 14px;
  bottom: 14px;
  padding: 18px;
  border-radius: 18px;
  background: rgba(255, 253, 248, 0.9);
  color: #2a1a4a;
  box-shadow: 0 8px 20px rgba(42, 26, 74, 0.14);
}

.aura-name,
.aura-theme,
.caption {
  display: block;
  text-align: center;
}

.aura-name {
  font-family: Georgia, serif;
  font-size: 22px;
  font-weight: 700;
}

.aura-theme {
  margin: 4px 0 14px;
  color: rgba(42, 26, 74, 0.65);
  font-size: 13px;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  padding: 9px 0;
  border-top: 1px solid rgba(212, 175, 55, 0.18);
  font-size: 12px;
  font-weight: 700;
}

.detail-row text:last-child {
  max-width: 160px;
  text-align: right;
}

.caption {
  margin-top: 12px;
  color: rgba(42, 26, 74, 0.82);
  font-family: Georgia, serif;
  font-size: 12px;
  font-style: italic;
  line-height: 17px;
}

.action-row {
  display: flex;
  justify-content: center;
  gap: 24px;
  margin-top: 18px;
}

.round-action {
  width: 76px;
  height: 76px;
  padding: 0;
  border-radius: 999px;
  border: 0;
  background: rgba(255, 255, 255, 0.9);
  color: #2a1a4a;
  font-size: 12px;
  font-weight: 800;
  box-shadow: 0 8px 18px rgba(42, 26, 74, 0.12);
}
