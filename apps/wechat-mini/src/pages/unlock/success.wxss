page {
  background: #ffe6ed;
}

.payment-success-page {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 70px 28px 38px;
  overflow: hidden;
  background: linear-gradient(180deg, #fff0ee 0%, #ffe6ed 50%, #ffd6e3 100%);
  color: #1c2945;
  font-family: "Plus Jakarta Sans", Inter, system-ui, sans-serif;
}

.sparkles {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.sparkle {
  position: absolute;
  color: #d4af37;
  font-size: 10px;
}

.sparkle.a {
  top: 78px;
  left: 40px;
}

.sparkle.b {
  top: 120px;
  right: 56px;
  color: #ff6b9e;
}

.sparkle.c {
  top: 250px;
  left: 22px;
}

.success-header {
  position: relative;
  z-index: 1;
  text-align: center;
  margin-bottom: 26px;
}

.success-icon {
  width: 86px;
  height: 86px;
  margin: 0 auto 20px;
  border-radius: 999px;
  background: linear-gradient(135deg, #ffd275, #e6a840);
  border: 6px solid rgba(255, 255, 255, 0.76);
  color: #ffffff;
  text-align: center;
  line-height: 86px;
  font-size: 12px;
  font-weight: 800;
  box-shadow: 0 0 34px rgba(255, 223, 137, 0.48);
}

.title {
  display: block;
  font-family: Georgia, serif;
  font-size: 34px;
  line-height: 40px;
  font-weight: 700;
}

.aura-card {
  position: relative;
  z-index: 1;
  min-height: 410px;
  border-radius: 24px;
  padding: 18px;
  background: linear-gradient(160deg, #47377b, #ff6b9e 52%, #f4c76b);
  border: 2px solid #e5c384;
  box-shadow: 0 18px 36px rgba(28, 41, 69, 0.18);
  color: #ffffff;
}

.card-top {
  display: grid;
  gap: 8px;
  padding: 18px 8px 120px;
  text-align: center;
}

.card-kicker {
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  opacity: 0.78;
}

.card-title {
  font-family: Georgia, serif;
  font-size: 26px;
}

.card-date {
  font-size: 12px;
  opacity: 0.86;
}

.card-panel {
  border-radius: 18px;
  padding: 18px;
  background: rgba(255, 255, 255, 0.88);
  color: #2d3748;
}

.aura-name,
.aura-theme {
  display: block;
  text-align: center;
}

.aura-name {
  font-family: Georgia, serif;
  font-size: 22px;
  font-weight: 700;
}

.aura-theme {
  margin: 4px 0 14px;
  color: #64748b;
  font-size: 14px;
}

.detail-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 0;
  border-top: 1px solid rgba(45, 55, 72, 0.1);
  font-size: 12px;
  font-weight: 700;
}

.actions {
  display: grid;
  gap: 12px;
  margin-top: 24px;
}

.primary-action,
.secondary-action {
  min-height: 58px;
  border-radius: 999px;
  font-weight: 800;
}

.primary-action::after,
.secondary-action::after {
  border: 0;
}

.primary-action {
  color: #ffffff;
  background: linear-gradient(90deg, #ff6b9e 0%, #ff4583 100%);
  box-shadow: 0 4px 15px rgba(255, 69, 131, 0.3);
}

.secondary-action {
  color: #1c2945;
  background: rgba(255, 255, 255, 0.82);
  border: 1px solid rgba(255, 214, 227, 0.8);
}
