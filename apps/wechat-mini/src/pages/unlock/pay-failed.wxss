page {
  background: #fdf7f0;
}

.payment-failed-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 48px 24px 34px;
  background: linear-gradient(180deg, #fdf7f0 0%, #fff0f0 100%);
  color: #1e293b;
  font-family: Nunito, Inter, system-ui, sans-serif;
}

.status-bar,
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.status-bar {
  margin-bottom: 24px;
  font-size: 13px;
  font-weight: 800;
}

.header {
  position: relative;
  justify-content: center;
  margin-bottom: 28px;
}

.brand,
.title {
  font-family: Georgia, serif;
}

.brand {
  font-size: 28px;
  color: #ff8e9e;
}

.circle-button {
  position: absolute;
  left: 0;
  width: 40px;
  height: 40px;
  border-radius: 999px;
  background: #ffffff;
  color: #64748b;
  font-size: 10px;
}

.circle-button::after,
.primary-action::after,
.secondary-action::after,
.support-link::after {
  border: 0;
}

.illustration {
  display: flex;
  justify-content: center;
  margin: 30px 0 26px;
}

.cloud {
  width: 230px;
  height: 152px;
  border-radius: 80px;
  background: #ffe5ec;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14px 34px rgba(255, 142, 158, 0.18);
}

.cloud text {
  width: 78px;
  height: 78px;
  border-radius: 999px;
  background: linear-gradient(180deg, #ff8e9e, #ff6b81);
  color: #ffffff;
  text-align: center;
  line-height: 78px;
  font-size: 52px;
  font-weight: 900;
}

.copy {
  text-align: center;
  margin-bottom: 34px;
}

.title {
  display: block;
  font-size: 34px;
  line-height: 40px;
  font-weight: 700;
}

.message {
  display: block;
  margin-top: 14px;
  color: #64748b;
  font-size: 16px;
  line-height: 24px;
}

.actions {
  display: grid;
  gap: 14px;
}

.primary-action,
.secondary-action {
  min-height: 58px;
  border-radius: 24px;
  font-weight: 800;
}

.primary-action {
  color: #ffffff;
  background: linear-gradient(90deg, #ff758c 0%, #ff7eb3 100%);
  box-shadow: 0 4px 14px rgba(255, 117, 140, 0.34);
}

.secondary-action {
  color: #1e293b;
  background: rgba(255, 255, 255, 0.64);
  border: 1px solid rgba(255, 255, 255, 0.82);
}

.support-link {
  margin: 34px auto 8px;
  display: block;
  color: #64748b;
  background: transparent;
  font-size: 14px;
}

.toast {
  display: block;
  text-align: center;
  color: #ff758c;
  font-size: 13px;
}
