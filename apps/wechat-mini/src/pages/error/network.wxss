page {
  background: #111111;
}

.error-page {
  position: relative;
  min-height: 100vh;
  padding: 46px 28px 34px;
  box-sizing: border-box;
  overflow: hidden;
  background: linear-gradient(180deg, #fdecf0 0%, #fff4e3 40%, #fdecf0 70%, #f5d3de 100%);
  color: #1b264f;
  font-family: Inter, system-ui, sans-serif;
}

.error-header {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 42px;
}

.close-button {
  position: absolute;
  left: 0;
  width: 40px;
  height: 40px;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.55);
  background: rgba(255, 255, 255, 0.42);
  color: #333333;
  font-size: 18px;
}

.close-button::after,
.retry-button::after,
.change-button::after {
  border: 0;
}

.brand-wrap {
  display: flex;
  align-items: center;
  gap: 6px;
}

.brand,
.error-title {
  font-family: Georgia, serif;
}

.brand {
  color: #e5b76c;
  font-size: 26px;
  font-weight: 700;
}

.brand-spark {
  color: #e5b76c;
  opacity: 0.72;
}

.hero-illustration {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 338px;
  margin-top: 36px;
}

.pink-glow {
  position: absolute;
  width: 280px;
  height: 280px;
  border-radius: 50%;
  background: rgba(255, 220, 227, 0.42);
  filter: blur(28px);
}

.moon-card {
  position: relative;
  width: 160px;
  height: 226px;
  border-radius: 18px;
  transform: rotate(-4deg);
  background: rgba(255, 255, 255, 0.9);
  border: 1px solid rgba(255, 220, 227, 0.68);
  box-shadow: 0 20px 40px rgba(255, 180, 195, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffdce3;
  font-size: 54px;
}

.card-border {
  position: absolute;
  inset: 8px;
  border: 1px solid rgba(255, 220, 227, 0.72);
  border-radius: 13px;
}

.cloud {
  position: absolute;
  bottom: 32px;
  width: 248px;
  height: 90px;
  border-radius: 90px 90px 34px 34px;
  background: rgba(255, 255, 255, 0.88);
  filter: drop-shadow(0 10px 20px rgba(255, 180, 195, 0.18));
}

.error-badge {
  position: absolute;
  right: 32px;
  bottom: 52px;
  width: 64px;
  height: 48px;
  border-radius: 28px;
  background: #ff849d;
  border: 2px solid #ffffff;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30px;
  font-weight: 700;
}

.error-copy {
  position: relative;
  z-index: 1;
  text-align: center;
  margin: 22px 0 84px;
}

.error-title {
  display: block;
  font-size: 28px;
  line-height: 34px;
  font-weight: 700;
}

.error-body {
  display: block;
  color: #6b7280;
  font-size: 15px;
  margin-top: 14px;
  font-weight: 600;
}

.error-actions {
  position: relative;
  z-index: 1;
  display: grid;
  gap: 16px;
}

.retry-button,
.change-button {
  height: 60px;
  border-radius: 999px;
  font-size: 17px;
}

.retry-button {
  border: 0;
  color: #ffffff;
  font-weight: 700;
  background: linear-gradient(90deg, #ff6b9a 0%, #ff4d85 100%);
  box-shadow: 0 8px 24px -6px rgba(255, 92, 141, 0.4);
}

.change-button {
  border: 1px solid #ffdce3;
  color: #1b264f;
  background: rgba(255, 255, 255, 0.42);
  font-weight: 600;
}
