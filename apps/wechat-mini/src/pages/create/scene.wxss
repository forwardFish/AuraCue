page {
  background: #f8f1e9;
  color: #10213d;
}

.scene-page {
  min-height: 100vh;
  background: radial-gradient(circle at top, #fffaf5 0%, #f8f1e9 100%);
  color: #10213d;
  display: flex;
  flex-direction: column;
  font-family: Inter, system-ui, sans-serif;
}

.status-bar,
.scene-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 24px;
  padding-right: 24px;
}

.status-bar {
  padding-top: 16px;
  padding-bottom: 26px;
}

.status-time {
  font-size: 14px;
  font-weight: 700;
}

.status-icons {
  font-size: 10px;
}

.scene-header {
  padding-bottom: 20px;
}

.back-button,
.header-spacer {
  width: 48px;
  height: 48px;
}

.back-button {
  border: 0;
  border-radius: 999px;
  background: #ffffff;
  color: #a68154;
  font-size: 32px;
  line-height: 44px;
  box-shadow: 0 8px 20px rgba(166, 129, 84, 0.08);
}

.back-button::after,
.scene-card::after,
.continue-button::after {
  border: 0;
}

.step-copy {
  color: #c59a65;
  font-size: 14px;
  font-weight: 700;
}

.scene-hero {
  text-align: center;
  padding: 0 24px 24px;
}

.scene-title {
  display: block;
  font-family: Georgia, serif;
  font-size: 39px;
  line-height: 43px;
  font-weight: 700;
}

.scene-copy {
  display: block;
  color: #6b7280;
  font-size: 14px;
  line-height: 21px;
  margin-top: 3px;
}

.scene-scroll {
  flex: 1;
  padding: 0 24px 122px;
  box-sizing: border-box;
}

.scene-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14px;
}

.scene-card {
  position: relative;
  min-height: 182px;
  border: 1px solid #eee4dc;
  border-radius: 28px;
  background: rgba(255, 255, 255, 0.78);
  padding: 12px;
  color: #10213d;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.04);
  text-align: center;
}

.scene-card-selected {
  border: 2px solid #e2b879;
  background: #fff8f3;
}

.selection-check {
  position: absolute;
  top: 10px;
  right: 10px;
  width: 28px;
  height: 28px;
  border-radius: 999px;
  background: #c4945c;
  color: #ffffff;
  line-height: 28px;
  font-size: 18px;
}

.scene-art {
  width: 112px;
  height: 92px;
  margin: 6px auto 12px;
  border-radius: 50px 50px 12px 12px;
  border: 1px solid #f1e2d7;
  background: #fff1f2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scene-art-work {
  background: #f2f4f7;
}

.scene-art-party {
  background: #fde8e8;
}

.scene-art-luck {
  background: #fef7eb;
}

.scene-art-icon {
  color: #c4945c;
  font-size: 11px;
}

.scene-label {
  display: block;
  font-family: Georgia, serif;
  font-size: 22px;
  line-height: 25px;
  font-weight: 700;
  margin-bottom: 8px;
}

.scene-description {
  display: block;
  color: #5f6673;
  font-size: 13px;
  line-height: 18px;
}

.sticky-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24px;
  background: linear-gradient(0deg, #f8f1e9 0%, rgba(248, 241, 233, 0.94) 72%, rgba(248, 241, 233, 0) 100%);
}

.continue-button {
  width: 100%;
  min-height: 58px;
  border: 0;
  border-radius: 999px;
  color: #ffffff;
  font-family: Georgia, serif;
  font-size: 26px;
  background: linear-gradient(180deg, #d9ad75 0%, #a67c4b 100%);
  box-shadow: 0 14px 30px rgba(166, 124, 75, 0.22);
}

.continue-disabled {
  color: #8b8b8b;
  background: #e7e1dd;
  box-shadow: inset 0 2px 6px rgba(0, 0, 0, 0.06);
}

.button-spark {
  margin-right: 12px;
}
