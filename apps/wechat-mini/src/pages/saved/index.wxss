.page {
  min-height: 100vh;
  padding: 96rpx 40rpx 40rpx;
  background: #fff8f5;
  color: #151642;
  text-align: center;
}
.brand {
  font-size: 36rpx;
  letter-spacing: 8rpx;
}
.title {
  margin-top: 80rpx;
  font-size: 58rpx;
  font-family: serif;
}
.copy {
  margin: 24rpx 0 44rpx;
  color: #70758d;
}
.saved-card {
  min-height: 520rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #f7d4eb, #efe4ff);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-family: serif;
}
.primary, .secondary {
  margin-top: 24rpx;
  border-radius: 48rpx;
}
.primary {
  background: linear-gradient(90deg, #8b54d9, #ff9b7a);
  color: white;
}
.secondary {
  border: 2rpx solid #d6a45c;
  background: transparent;
  color: #151642;
}
