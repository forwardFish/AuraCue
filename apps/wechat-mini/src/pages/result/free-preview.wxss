page {
  background: #fdf9f6;
}

.free-preview-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  box-sizing: border-box;
  padding: 48px 20px 178px;
  background: #fdf9f6;
  color: #1f2937;
  font-family: Inter, system-ui, sans-serif;
}

.top-fade {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 220px;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(253, 249, 246, 0));
}

.top-bar {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 40px 1fr 40px;
  align-items: center;
  gap: 8px;
}

.round-button {
  width: 40px;
  height: 40px;
  border: 0;
  border-radius: 999px;
  background: #ffffff;
  color: #6b7280;
  font-size: 11px;
  line-height: 40px;
  box-shadow: 0 5px 16px rgba(0, 0, 0, 0.05);
}

.round-button::after {
  border: 0;
}

.page-title,
.aura-name {
  font-family: Georgia, serif;
}

.page-title {
  color: #121a3b;
  font-size: 28px;
  line-height: 30px;
  font-weight: 500;
  text-align: center;
}

.context {
  position: relative;
  z-index: 1;
  text-align: center;
  margin: 24px 0;
}

.context-line {
  display: flex;
  justify-content: center;
  gap: 8px;
  color: #121a3b;
  font-size: 15px;
  font-weight: 600;
}

.dot {
  color: #9ca3af;
}

.accent {
  color: #d47b78;
}

.context-copy {
  display: block;
  margin-top: 8px;
  color: #6b7280;
  font-size: 13px;
}

.content-scroll {
  position: relative;
  z-index: 1;
  height: calc(100vh - 260px);
}

.aura-card {
  display: grid;
  grid-template-columns: 134px 1fr;
  gap: 14px;
  padding: 16px;
  border-radius: 32px;
  color: #ffffff;
  background: linear-gradient(135deg, #2d3a5f 0%, #d4a39b 100%);
  box-shadow: 0 16px 40px rgba(0, 0, 0, 0.1);
}

.preview-art {
  position: relative;
  min-height: 220px;
  border-radius: 20px;
  overflow: hidden;
  background: linear-gradient(160deg, #15213e, #8d5bff 50%, #f4c76b);
  border: 1px solid rgba(255, 255, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.preview-label {
  font-family: Georgia, serif;
  font-size: 18px;
  font-weight: 700;
}

.watermark {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 18px;
  padding: 8px 0;
  background: rgba(18, 26, 59, 0.55);
  letter-spacing: 2px;
  text-transform: uppercase;
  font-size: 10px;
}

.aura-details {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 6px 0;
}

.kicker {
  font-size: 10px;
  letter-spacing: 2px;
  opacity: 0.88;
}

.aura-name {
  display: block;
  margin: 7px 0 8px;
  font-size: 29px;
  line-height: 31px;
  font-weight: 500;
  text-shadow: 0 2px 10px rgba(255, 255, 255, 0.42);
}

.reminder {
  display: block;
  margin-bottom: 18px;
  font-size: 13px;
  line-height: 18px;
  opacity: 0.92;
}

.info-card {
  border-radius: 20px;
  padding: 12px;
  background: rgba(255, 255, 255, 0.9);
  color: #121a3b;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
}

.color-row {
  display: flex;
  gap: 10px;
  align-items: center;
}

.swatch {
  width: 34px;
  height: 34px;
  border-radius: 999px;
  background: #f4c76b;
  box-shadow: inset 0 0 0 8px rgba(255, 255, 255, 0.24);
}

.label {
  display: block;
  color: #6b7280;
  font-size: 10px;
  letter-spacing: 1px;
  text-transform: uppercase;
  font-weight: 700;
}

.color-name {
  display: block;
  color: #121a3b;
  font-size: 14px;
  font-weight: 700;
}

.locked-panel {
  margin-top: 22px;
  border-radius: 32px;
  padding: 8px;
  background: rgba(255, 255, 255, 0.62);
  border: 1px solid rgba(255, 255, 255, 0.55);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
}

.locked-row {
  display: grid;
  grid-template-columns: 48px 1fr 38px;
  align-items: center;
  gap: 12px;
  padding: 12px;
}

.locked-icon {
  width: 48px;
  height: 48px;
  border-radius: 999px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #a08875;
  background: #f6f2ec;
  font-size: 10px;
  filter: blur(1.5px);
}

.locked-copy {
  filter: blur(4px);
  user-select: none;
}

.locked-title {
  display: block;
  color: #1f2937;
  font-size: 15px;
  font-weight: 700;
}

.locked-teaser {
  display: block;
  margin-top: 3px;
  color: #9ca3af;
  font-size: 13px;
  line-height: 17px;
}

.lock-badge {
  width: 38px;
  height: 38px;
  border-radius: 999px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #a08875;
  background: #fdf9f6;
  font-size: 9px;
  border: 1px solid #e5e7eb;
}

.bottom-actions {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2;
  padding: 54px 20px 18px;
  background: linear-gradient(0deg, #fdf9f6 0%, #fdf9f6 72%, rgba(253, 249, 246, 0));
  display: grid;
  gap: 12px;
}

.primary-action,
.secondary-action {
  min-height: 60px;
  border-radius: 999px;
  font-weight: 600;
  font-size: 16px;
}

.primary-action {
  border: 0;
  color: #ffffff;
  background: linear-gradient(90deg, #d6a875, #b78a5b);
  box-shadow: 0 12px 24px rgba(183, 138, 91, 0.24);
}

.secondary-action {
  border: 1px solid #d6a875;
  color: #a07044;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
}

.secondary-action::after,
.primary-action::after {
  border: 0;
}

.progress-pill {
  color: #d47b78;
  background: #f8eaeb;
  border-radius: 999px;
  padding: 4px 10px;
  font-size: 13px;
}

.privacy-copy {
  color: #6b7280;
  font-size: 12px;
  text-align: center;
}
