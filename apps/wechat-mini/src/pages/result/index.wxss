.page {
  min-height: 100vh;
  padding: 76rpx 40rpx 40rpx;
  background: #fffaf7;
  color: #151642;
}
.brand, .title {
  text-align: center;
}
.brand {
  font-size: 36rpx;
  letter-spacing: 8rpx;
}
.title {
  margin: 48rpx 0 36rpx;
  font-size: 54rpx;
  font-family: serif;
}
.card, .panel {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.84);
}
.eyebrow {
  color: #d95d82;
  text-transform: uppercase;
}
.aura {
  margin-top: 12rpx;
  font-size: 48rpx;
  font-family: serif;
}
.copy {
  margin-top: 20rpx;
  color: #66708a;
}
.primary, .secondary {
  margin-top: 20rpx;
  border-radius: 48rpx;
}
.primary {
  background: linear-gradient(90deg, #8b54d9, #ff9b7a);
  color: white;
}
.secondary {
  border: 2rpx solid #d6a45c;
  background: transparent;
  color: #151642;
}
