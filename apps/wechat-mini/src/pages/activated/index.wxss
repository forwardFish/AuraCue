.page {
  min-height: 100vh;
  padding: 96rpx 40rpx 40rpx;
  background: #fff7f5;
  color: #151642;
  text-align: center;
}
.brand {
  font-size: 36rpx;
  letter-spacing: 8rpx;
}
.title {
  margin-top: 120rpx;
  font-size: 64rpx;
  font-family: serif;
}
.copy {
  margin-top: 20rpx;
  color: #70758d;
}
.card {
  margin: 56rpx 0;
  padding: 40rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.84);
}
.aura {
  margin-bottom: 24rpx;
  font-size: 46rpx;
  font-family: serif;
}
.primary, .secondary {
  margin-top: 20rpx;
  border-radius: 48rpx;
}
.primary {
  background: linear-gradient(90deg, #8b54d9, #ff9b7a);
  color: white;
}
.secondary {
  border: 2rpx solid #d6a45c;
  background: transparent;
  color: #151642;
}
