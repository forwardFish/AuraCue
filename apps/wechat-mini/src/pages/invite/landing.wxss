page {
  background: #ffebee;
}

.friend-landing-page {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 48px 24px 36px;
  overflow: hidden;
  background: linear-gradient(180deg, #fff5f4 0%, #ffebee 100%);
  color: #1a2352;
  text-align: center;
  font-family: Inter, system-ui, sans-serif;
}

.friend-landing-page::before,
.friend-landing-page::after {
  content: "";
  position: absolute;
  width: 520px;
  height: 520px;
  border-radius: 999px;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.82) 0%, rgba(255, 255, 255, 0) 70%);
}

.friend-landing-page::before {
  left: -270px;
  top: 420px;
}

.friend-landing-page::after {
  right: -300px;
  top: 560px;
}

.brand,
.title,
.invite-copy,
.card-title {
  position: relative;
  z-index: 1;
  font-family: Georgia, serif;
}

.brand {
  display: block;
  margin-bottom: 24px;
  font-size: 32px;
  font-weight: 700;
}

.profile {
  position: relative;
  z-index: 1;
  width: 72px;
  height: 72px;
  margin: 0 auto 22px;
  border-radius: 999px;
  border: 2px solid #ffb347;
  background: #ffffff;
  color: #ff758c;
  font-weight: 800;
  line-height: 72px;
  box-shadow: 0 8px 20px rgba(233, 114, 151, 0.18);
}

.title {
  display: block;
  margin: 0 auto 28px;
  max-width: 280px;
  font-size: 28px;
  line-height: 34px;
}

.locked-card {
  position: relative;
  z-index: 1;
  width: 280px;
  height: 360px;
  margin: 0 auto 28px;
  border-radius: 18px;
  overflow: hidden;
  background: linear-gradient(135deg, #a88beb 0%, #f8ceec 100%);
  box-shadow: 0 10px 25px rgba(233, 114, 151, 0.2);
  color: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.locked-card::before {
  content: "";
  position: absolute;
  inset: 6px;
  border: 1px solid rgba(255, 215, 0, 0.6);
  border-radius: 14px;
}

.card-kicker {
  position: absolute;
  top: 24px;
  left: 0;
  right: 0;
  text-transform: uppercase;
  letter-spacing: 2px;
  font-size: 10px;
}

.card-title {
  position: absolute;
  top: 48px;
  left: 0;
  right: 0;
  font-size: 22px;
}

.lock-icon {
  width: 76px;
  height: 76px;
  border-radius: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.3);
  color: #ffffff;
  font-size: 14px;
}

.invite-copy {
  display: block;
  margin: 0 auto 20px;
  font-size: 18px;
  line-height: 24px;
}

.primary-action {
  position: relative;
  z-index: 1;
  min-height: 62px;
  border: 0;
  border-radius: 30px;
  color: #ffffff;
  background: linear-gradient(90deg, #ff758c 0%, #ff7eb3 100%);
  box-shadow: 0 8px 20px rgba(255, 117, 140, 0.32);
  font-size: 18px;
  font-weight: 700;
}

.primary-action::after {
  border: 0;
}

.helper-copy {
  position: relative;
  z-index: 1;
  margin-top: 24px;
  color: #1a2352;
  font-size: 14px;
}
