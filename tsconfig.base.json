{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@auracue/shared-types": ["packages/shared-types/src/index.ts"],
      "@auracue/ui-tokens": ["packages/ui-tokens/src/index.ts"],
      "@auracue/analytics-events": ["packages/analytics-events/src/index.ts"],
      "@auracue/card-renderer": ["packages/card-renderer/src/index.ts"],
      "@auracue/prompt-core": ["packages/prompt-core/src/index.ts"]
    }
  }
}
